{
  "name": "claude-monitor",
  "version": "1.0.3",
  "description": "Claude 사용량 실시간 모니터",
  "main": "electron_main.js",
  "scripts": {
    "start": "electron .",
    "dist": "npx electron-builder --mac"
  },
  "build": {
    "appId": "io.github.kyutaekjung-wq.claude-usage-monitor-tool",
    "productName": "Claude Monitor",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "icon.icns"
    },
    "dmg": {
      "title": "Claude Monitor Installer",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  },
  "dependencies": {
    "playwright-core": "^1.48.0",
    "pngjs": "^7.0.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^25.0.0"
  }
}
